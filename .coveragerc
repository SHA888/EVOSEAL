[run]
source = evoseal
branch = True
omit =
    */tests/*
    */__init__.py
    */version.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self\.debug
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    @(abc\.)?abstractmethod
    if TYPE_CHECKING:
ignore_errors = True
data_file = .coverage

[html]
directory = htmlcov
title = EVOSEAL Test Coverage
